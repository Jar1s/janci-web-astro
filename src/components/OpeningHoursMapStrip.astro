---
/**
 * Široký pás: otváracie hodiny + mapa.
 * Použitie pod Hero na úvodnej stránke — rovnaká farebná rodina ako .hero (#0a1628).
 */
const mapsEmbedSrc =
  'https://www.google.com/maps?q=JP+Control+Šenkvická+cesta+14+Pezinok&output=embed&hl=sk&z=16';
---

<section
  class="opening-strip relative z-[4] w-full border-t border-white/10 bg-[#0a1628] px-4 pb-14 pt-10 md:px-6 md:pb-16 md:pt-12"
  aria-labelledby="opening-strip-title"
>
  <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-2 lg:gap-10 lg:items-stretch">
    <!-- Hodiny -->
    <div class="flex flex-col">
      <h2
        id="opening-strip-title"
        class="mb-6 text-center text-2xl font-bold text-white md:text-left md:text-3xl"
        data-translate="section-hours"
      >
        Otváracie hodiny
      </h2>
      <div
        class="flex min-h-0 flex-1 flex-col overflow-hidden rounded-2xl border border-white/10 bg-white/95 shadow-xl shadow-black/20"
      >
        <div class="bg-primary px-6 py-4 md:px-8 md:py-5">
          <h3 class="flex items-center justify-center gap-3 text-center text-lg font-semibold text-white md:text-xl">
            <svg class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span data-translate="hours-title">Otváracie hodiny</span>
          </h3>
        </div>

        <div class="divide-y divide-gray-100">
          <div class="flex items-center justify-between px-6 py-3.5 md:px-8 md:py-4">
            <span class="font-medium text-gray-800" data-translate="day-mon">Pondelok</span>
            <span class="text-lg font-semibold text-primary">6:00 – 19:00</span>
          </div>
          <div class="flex items-center justify-between bg-white px-6 py-3.5 md:px-8 md:py-4">
            <span class="font-medium text-gray-800" data-translate="day-tue">Utorok</span>
            <span class="text-lg font-semibold text-primary">6:00 – 16:00</span>
          </div>
          <div class="flex items-center justify-between px-6 py-3.5 md:px-8 md:py-4">
            <span class="font-medium text-gray-800" data-translate="day-wed">Streda</span>
            <span class="text-lg font-semibold text-primary">6:00 – 16:00</span>
          </div>
          <div class="flex items-center justify-between bg-white px-6 py-3.5 md:px-8 md:py-4">
            <span class="font-medium text-gray-800" data-translate="day-thu">Štvrtok</span>
            <span class="text-lg font-semibold text-primary">6:00 – 16:00</span>
          </div>
          <div class="flex items-center justify-between px-6 py-3.5 md:px-8 md:py-4">
            <span class="font-medium text-gray-800" data-translate="day-fri">Piatok</span>
            <span class="text-lg font-semibold text-primary">6:00 – 16:00</span>
          </div>
          <div class="flex items-center justify-between bg-white px-6 py-3.5 md:px-8 md:py-4">
            <span class="font-medium text-gray-800" data-translate="day-sat">Sobota</span>
            <span class="text-lg font-semibold text-red-500" data-translate="closed">Zatvorené</span>
          </div>
          <div class="flex items-center justify-between px-6 py-3.5 md:px-8 md:py-4">
            <span class="font-medium text-gray-800" data-translate="day-sun">Nedeľa</span>
            <span class="text-lg font-semibold text-red-500" data-translate="closed">Zatvorené</span>
          </div>
        </div>

        <div class="bg-primary/10 px-6 py-4 text-center md:px-8">
          <p class="text-sm text-gray-700">
            <span class="font-semibold text-primary" data-translate="nonstop-note">NONSTOP telefón</span><span data-translate="nonstop-note-desc"> – kontaktujte nás kedykoľvek</span>
          </p>
          <p class="mt-2 text-xs text-gray-500" data-translate="address-short">
            Šenkvická cesta 14/F, 902 01 Pezinok
          </p>
        </div>
      </div>
    </div>

    <!-- Mapa -->
    <div class="flex min-h-[280px] flex-col lg:min-h-0">
      <h3 class="mb-6 text-center text-2xl font-bold text-white md:text-left md:text-3xl" data-translate="section-map">
        Kde nás nájdete
      </h3>
      <div
        class="relative min-h-[280px] flex-1 overflow-hidden rounded-2xl border border-white/10 bg-slate-800 shadow-xl shadow-black/25 ring-1 ring-white/5 lg:min-h-[360px]"
      >
        <iframe
          title="Mapa – JP Control Pezinok, Šenkvická cesta 14/F"
          src={mapsEmbedSrc}
          class="absolute inset-0 h-full w-full border-0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        />
      </div>
      <a
        href="https://www.google.com/maps/search/?api=1&query=JP+Control+Pezinok+Šenkvická+cesta+14"
        class="mt-3 inline-flex items-center justify-center gap-2 text-sm font-medium text-sky-300 underline-offset-2 hover:text-white hover:underline md:justify-start"
        target="_blank"
        rel="noopener noreferrer"
        data-translate="maps-open-route"
      >
        Otvoriť trasu v Google Maps
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  </div>
</section>
