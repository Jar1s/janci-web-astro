---
const currentYear = new Date().getFullYear();
---

<footer class="footer" id="kontakt-footer">
  <div class="footer-container">
    <div class="footer-grid">
      <!-- Column 1: Company -->
      <div class="footer-col">
        <h3 class="footer-heading">JP Control s.r.o.</h3>
        <p class="footer-description" data-translate="footer-desc">
          Vaša spoľahlivá stanica technickej a emisnej kontroly v Pezinku. Certifikovaná podľa ISO 9001:2015 a ISO 37001:2016.
        </p>
        <div class="social-links">
          <a href="https://www.facebook.com" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <a href="https://www.instagram.com" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
              <rect x="2" y="9" width="4" height="12"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Column 2: Kontakt -->
      <div class="footer-col">
        <h3 class="footer-heading" data-translate="footer-contact">Kontakt</h3>
        <ul class="contact-list">
          <li class="contact-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="contact-icon" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <span>Šenkvická cesta 14/F, 902 01 Pezinok</span>
          </li>
          <li class="contact-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="contact-icon" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <a href="tel:+421948888088">0948 888 088 (NONSTOP)</a>
          </li>
          <li class="contact-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="contact-icon" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            <a href="mailto:stk@kontrolavozidiel.sk">stk@kontrolavozidiel.sk</a>
          </li>
        </ul>
      </div>

      <!-- Column 3: Rýchle odkazy -->
      <div class="footer-col">
        <h3 class="footer-heading">Rýchle odkazy</h3>
        <ul class="footer-nav">
          <li><a href="/">Úvod</a></li>
          <li><a href="/o-nas">O nás</a></li>
          <li><a href="/technicka-kontrola">Technická kontrola</a></li>
          <li><a href="/emisna-kontrola">Emisná kontrola</a></li>
          <li><a href="/kontrola-originality">Kontrola originality</a></li>
          <li><a href="/cennik">Cenník</a></li>
          <li><a href="/kontakt">Kontakt</a></li>
          <li><a href="/legislativa">Platná legislatíva</a></li>
          <li><a href="/kategorie-vozidiel">Kategórie vozidiel</a></li>
          <li><a href="/povinna-vybava">Povinná výbava</a></li>
        </ul>
      </div>

      <!-- Column 4: Otváracie hodiny -->
      <div class="footer-col">
        <h3 class="footer-heading" data-translate="footer-hours">Otváracie hodiny</h3>
        <ul class="hours-list">
          <li class="hours-row">
            <span data-translate="footer-mon">Pondelok</span>
            <span>06:00 – 19:00</span>
          </li>
          <li class="hours-row">
            <span data-translate="footer-tue-fri">Utorok – Piatok</span>
            <span>06:00 – 16:00</span>
          </li>
          <li class="hours-row">
            <span data-translate="footer-sat-sun">Sobota – Nedeľa</span>
            <span data-translate="footer-closed">Zatvorené</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Footer Bottom -->
    <div class="footer-bottom">
      <p>Copyright {currentYear} &copy; www.kontrolavozidiel.sk</p>
      <p class="footer-legal">IČO: 45 464 162 | DIČ: 2023210079 | IČ DPH: SK2023210079</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: #1a1a1a;
    color: #a0a0a0;
    padding: 4rem 1.25rem 2rem;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2.5rem;
    margin-bottom: 3rem;
  }

  .footer-heading {
    color: #ffffff;
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
  }

  .footer-description {
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  /* Social Links */
  .social-links {
    display: flex;
    gap: 0.75rem;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.1);
    color: #a0a0a0;
    transition: background-color 0.3s ease, color 0.3s ease;
    text-decoration: none;
  }

  .social-icon:hover {
    background-color: #0066cc;
    color: #ffffff;
  }

  /* Contact List */
  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    line-height: 1.4;
  }

  .contact-icon {
    flex-shrink: 0;
    margin-top: 2px;
    color: #a0a0a0;
  }

  .contact-item a {
    color: #a0a0a0;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .contact-item a:hover {
    color: #0066cc;
  }

  /* Hours List */
  .hours-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .hours-row {
    display: flex;
    justify-content: space-between;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* Footer Nav */
  .footer-nav {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer-nav a {
    color: #a0a0a0;
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s ease, padding-left 0.2s ease;
    display: block;
  }

  .footer-nav a:hover {
    color: #0066cc;
    padding-left: 4px;
  }

  /* Footer Bottom */
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 2rem;
    text-align: center;
    font-size: 0.875rem;
  }

  .footer-bottom p {
    margin: 0;
  }

  .footer-legal {
    margin-top: 0.5rem !important;
    font-size: 0.8125rem;
    color: #777777;
  }

  /* Links global */
  .footer a {
    color: #a0a0a0;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .footer a:hover {
    color: #0066cc;
  }
</style>
