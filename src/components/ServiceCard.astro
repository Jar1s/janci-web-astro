---
interface Props {
  title: string;
  description: string;
  image: string;
  badge: string;
  href: string;
}

const { title, description, image, badge, href } = Astro.props;
---

<a href={href} class="service-card tilt-card">
  <div class="service-card__header">
    <img src={image} alt={title} class="service-card__image" loading="lazy" />
  </div>
  <div class="service-card__content">
    <span class="service-card__badge">{badge}</span>
    <h3 class="service-card__title">{title}</h3>
    <p class="service-card__description">{description}</p>
    <span class="service-card__link">
      Zistiť viac
      <svg class="service-card__arrow" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </span>
  </div>
</a>

<style>
  .service-card {
    display: block;
    background: #ffffff;
    border-radius: 8px;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1);
    border: 1px solid #e5e7eb;
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .service-card:hover {
    transform: translateY(-10px) scale(1.02);
    box-shadow: 0 20px 40px -8px rgba(0, 102, 204, 0.2), 0 8px 16px -4px rgba(0, 102, 204, 0.1);
  }

  .service-card:hover .service-card__content {
    background: #0066cc;
  }

  .service-card:hover .service-card__badge {
    background: rgba(255, 255, 255, 0.2);
    color: #fff;
  }

  .service-card:hover .service-card__title {
    color: #fff !important;
    -webkit-text-fill-color: #fff !important;
    background: none !important;
    -webkit-background-clip: unset !important;
  }

  .service-card:hover .service-card__description {
    color: rgba(255, 255, 255, 0.9) !important;
  }

  .service-card:hover .service-card__link {
    color: #fff !important;
    -webkit-text-fill-color: #fff !important;
  }

  .service-card__header {
    height: 240px;
    background: linear-gradient(180deg, #e6f2ff 0%, #ffffff 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }

  .service-card__image {
    max-width: 100%;
    max-height: 100%;
    height: 100%;
    object-fit: contain;
  }

  .service-card__content {
    padding: 2.5rem;
    transition: background 0.3s ease;
  }

  .service-card__badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.375rem 0.75rem;
    border-radius: 20px;
    background-color: #e6f2ff;
    color: #0066cc;
    margin-bottom: 1rem;
  }

  .service-card__title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 1rem 0;
    line-height: 1.3;
    transition: color 0.3s ease;
  }

  .service-card__description {
    font-size: 1rem;
    color: #374151;
    line-height: 1.7;
    margin: 0 0 1.5rem 0;
    transition: color 0.3s ease;
  }

  .service-card:hover .service-card__title {
    color: #0052a3;
  }

  .service-card:hover .service-card__description {
    color: #1a1a1a;
  }

  .service-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: #0066cc;
    font-weight: 600;
    font-size: 1rem;
    transition: gap 0.3s ease;
  }

  .service-card:hover .service-card__link {
    gap: 0.75rem;
  }

  .service-card__arrow {
    transition: transform 0.3s ease;
  }

  .service-card:hover .service-card__arrow {
    transform: translateX(4px);
  }
</style>
