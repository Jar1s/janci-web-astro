---
// FloatingPhone — sticky CTA phone button, bottom-right with pulse & hover label
---

<a href="tel:+421948888088" class="floating-phone" aria-label="Zavolajte nám: +421 948 888 088" id="floating-phone-btn">
  <span class="floating-phone__label">Zavolajte nám</span>
  <span class="floating-phone__icon">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
    </svg>
  </span>
</a>

<style>
  .floating-phone {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 999;
    display: flex;
    align-items: center;
    gap: 0;
    text-decoration: none;
    outline: none;
  }

  .floating-phone__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #0066cc;
    color: #fff;
    box-shadow: 0 4px 15px rgba(0, 102, 204, 0.4);
    transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
    animation: phone-pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  .floating-phone:hover .floating-phone__icon {
    transform: scale(1.1);
    background: #0077ee;
    box-shadow: 0 6px 25px rgba(0, 102, 204, 0.6);
    animation: none;
  }

  .floating-phone__label {
    display: block;
    background: #0066cc;
    color: #fff;
    font-size: 0.8125rem;
    font-weight: 600;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    white-space: nowrap;
    opacity: 0;
    transform: translateX(10px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    pointer-events: none;
    margin-right: 0.625rem;
    box-shadow: 0 2px 10px rgba(0, 102, 204, 0.3);
  }

  .floating-phone:hover .floating-phone__label {
    opacity: 1;
    transform: translateX(0);
  }

  @keyframes phone-pulse {
    0%, 100% {
      box-shadow: 0 4px 15px rgba(0, 102, 204, 0.4);
    }
    50% {
      box-shadow: 0 4px 25px rgba(0, 102, 204, 0.7), 0 0 0 8px rgba(0, 102, 204, 0.15);
    }
  }

  @media (max-width: 380px) {
    .floating-phone {
      bottom: 1rem;
      right: 1rem;
    }
    .floating-phone__icon {
      width: 48px;
      height: 48px;
    }
    .floating-phone__label {
      display: none;
    }
  }
</style>
