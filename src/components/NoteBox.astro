---
interface Props {
  type?: 'info' | 'warning';
}

const { type = 'info' } = Astro.props;

const styles = {
  info: 'bg-sky-50 border-sky-300 text-sky-900',
  warning: 'bg-amber-50 border-amber-300 text-amber-900',
};

const iconColor = type === 'warning' ? 'text-amber-500' : 'text-sky-500';
---

<div class={`border rounded-lg p-5 flex gap-4 items-start max-w-3xl mx-auto ${styles[type]}`} role="note">
  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={`shrink-0 mt-0.5 ${iconColor}`} aria-hidden="true">
    <circle cx="12" cy="12" r="10"></circle>
    <line x1="12" y1="16" x2="12" y2="12"></line>
    <line x1="12" y1="8" x2="12.01" y2="8"></line>
  </svg>
  <div class="text-[0.95rem]">
    <slot />
  </div>
</div>
