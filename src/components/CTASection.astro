---
interface Props {
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
}

const {
  title,
  subtitle,
  ctaText = 'Rezervovať termín teraz',
  ctaHref = 'https://www.kontrolavozidiel.sk/rezervovat-cez-internet',
} = Astro.props;
---

<section class="cta-section">
  <div class="cta-container">
    <h2 class="cta-title">{title}</h2>
    {subtitle && (
      <p class="cta-subtitle">{subtitle}</p>
    )}
    <a
      href={ctaHref}
      class="cta-button magnetic-btn pulse-glow"
      rel="noopener noreferrer"
    >
      {ctaText}
    </a>
  </div>
</section>

<style>
  .cta-section {
    background: linear-gradient(135deg, #0066cc 0%, #004d99 100%);
    color: #fff;
    text-align: center;
    padding: 5rem 0;
  }

  .cta-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .cta-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 1rem;
  }

  .cta-subtitle {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.85);
    max-width: 600px;
    margin: 0 auto 2.5rem;
  }

  .cta-button {
    display: inline-block;
    background: #fff;
    color: #0066cc;
    border-radius: 4px;
    padding: 1rem 2rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .cta-button:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.25);
  }
</style>
