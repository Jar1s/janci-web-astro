---
/**
 * CookieConsent – fixed bottom bar.
 * Saves user choice to localStorage. Appears after 1 s if no choice stored.
 */
---

<div id="cookie-consent" class="cookie-bar" aria-live="polite" role="dialog" aria-label="Cookie consent">
  <div class="cookie-inner">
    <p class="cookie-text">
      Táto webová stránka používa cookies na zlepšenie vášho zážitku z prehliadania.
      Používaním stránky súhlasíte s ich používaním.
    </p>
    <div class="cookie-actions">
      <button id="cookie-accept" class="cookie-btn cookie-btn--accept" type="button">
        Prijať
      </button>
      <button id="cookie-reject" class="cookie-btn cookie-btn--reject" type="button">
        Odmietnuť
      </button>
    </div>
  </div>
</div>

<script>
  (function () {
    'use strict';

    var STORAGE_KEY = 'cookie-consent';
    var bar = document.getElementById('cookie-consent');
    var acceptBtn = document.getElementById('cookie-accept');
    var rejectBtn = document.getElementById('cookie-reject');

    if (!bar || !acceptBtn || !rejectBtn) return;

    // If choice already saved, don't show
    var saved = null;
    try {
      saved = localStorage.getItem(STORAGE_KEY);
    } catch (e) {
      // localStorage may not be available
    }

    if (saved) return;

    // Show after 1s delay
    setTimeout(function () {
      bar.classList.add('cookie-bar--visible');
    }, 1000);

    function saveChoice(value) {
      try {
        localStorage.setItem(STORAGE_KEY, value);
      } catch (e) {
        // ignore
      }
      bar.classList.remove('cookie-bar--visible');
    }

    acceptBtn.addEventListener('click', function () {
      saveChoice('accepted');
    });

    rejectBtn.addEventListener('click', function () {
      saveChoice('rejected');
    });
  })();
</script>

<style>
  .cookie-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    background: #1a1a2e;
    color: #fff;
    padding: 1.25rem 1.5rem;
    transform: translateY(100%);
    transition: transform 0.4s ease;
  }

  .cookie-bar--visible {
    transform: translateY(0);
  }

  .cookie-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .cookie-text {
    flex: 1 1 400px;
    font-size: 0.9375rem;
    line-height: 1.6;
    margin: 0;
    color: rgba(255, 255, 255, 0.9);
  }

  .cookie-actions {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .cookie-btn {
    border: none;
    border-radius: 6px;
    padding: 0.625rem 1.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .cookie-btn:hover {
    transform: translateY(-1px);
  }

  .cookie-btn--accept {
    background: #0066cc;
    color: #fff;
  }

  .cookie-btn--accept:hover {
    background: #0055b3;
  }

  .cookie-btn--reject {
    background: transparent;
    color: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.3);
  }

  .cookie-btn--reject:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
  }

  @media (max-width: 640px) {
    .cookie-inner {
      flex-direction: column;
      text-align: center;
    }

    .cookie-actions {
      width: 100%;
      justify-content: center;
    }
  }
</style>
