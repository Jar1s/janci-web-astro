  <div class="mobile-drawer-overlay" id="mobile-drawer-overlay"></div>
  <div class="mobile-drawer-panel" id="mobile-drawer-panel">
    <div class="mobile-drawer-header">
      <a href="/" class="mobile-logo">
        <span class="logo-text">JP Control s.r.o.</span>
        <img
          src="/images/PTI_icons.webp"
          alt="TK, EK, KO"
          class="logo-pti-icons"
          width="100"
          height="20"
          loading="lazy"
        />
      </a>
      <button class="mobile-close-btn" id="mobile-close-btn" aria-label="Zatvoriť menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <nav class="mobile-nav" aria-label="Mobilná navigácia">
      <ul class="mobile-nav-list" role="list">
        {allNavItems.map(item => (
          <li>
            <a
              href={item.href}
              class:list={[
                'mobile-nav-link',
                { active: currentPath === item.href },
                { 'mobile-btn-rezervovat': item.href === '/rezervacia' }
