---
interface Props {
  currentPath?: string;
}

const { currentPath = '' } = Astro.props;

const leftNavItems = [
  { href: '/o-nas', label: 'O NÁS', key: 'nav-about' },
  { href: '/#sluzby', label: 'SLUŽBY', key: 'nav-services' },
  { href: '/cennik', label: 'CENNÍK', key: 'nav-pricing' },
];

const rightNavItems = [
  { href: '/recenzie', label: 'RECENZIE', key: 'nav-reviews' },
  { href: '/kontakt', label: 'KONTAKT', key: 'nav-contact' },
];

const allNavItems = [
  ...leftNavItems,
  { href: '/legislativa', label: 'PLATNÁ LEGISLATÍVA' },
  { href: '/kategorie-vozidiel', label: 'KATEGÓRIE VOZIDIEL' },
  { href: '/povinna-vybava', label: 'POVINNÁ VÝBAVA' },
  ...rightNavItems,
  { href: 'https://www.kontrolavozidiel.sk/rezervovat-cez-internet', label: 'REZERVOVAŤ' },
];
---

<nav class="navbar" id="navbar" aria-label="Hlavná navigácia">
  <div class="navbar-inner">

    <!-- Language Switcher (order: 1) -->
    <div class="navbar-left-extras">
      <div class="lang-switcher">
        <button class="lang-btn active" data-lang="sk" aria-label="Slovenčina" aria-current="true">SK</button>
        <span class="lang-separator">|</span>
        <button class="lang-btn" data-lang="en" aria-label="English">EN</button>
      </div>
    </div>

    <!-- Left Nav Links (order: 2) -->
    <ul class="nav-menu nav-menu-left" role="list">
      {leftNavItems.map(item => (
        <li>
          <a
            href={item.href}
            class:list={['nav-link', { active: currentPath === item.href }]}
            data-translate={item.key}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Center Logo (order: 3) -->
    <div class="logo-wrapper">
      <a href="/" class="logo" aria-label="JP Control s.r.o. - Domov">
        <span class="logo-text">JP Control s.r.o.</span>
      </a>
      <div class="logo-service-icons">
        <a href="/technicka-kontrola" class="service-icon-link" title="Technická kontrola" data-astro-reload>
          <img src="/images/TK.png" alt="Technická kontrola" class="service-icon-img" width="40" height="24" loading="eager" />
        </a>
        <a href="/emisna-kontrola" class="service-icon-link" title="Emisná kontrola" data-astro-reload>
          <img src="/images/EK.png" alt="Emisná kontrola" class="service-icon-img" width="40" height="24" loading="eager" />
        </a>
        <a href="/kontrola-originality" class="service-icon-link" title="Kontrola originality" data-astro-reload>
          <img src="/images/KO.png" alt="Kontrola originality" class="service-icon-img" width="40" height="24" loading="eager" />
        </a>
      </div>
    </div>

    <!-- Right Nav Links (order: 4) -->
    <ul class="nav-menu nav-menu-right" role="list">
      <!-- Informácie dropdown -->
      <li class="info-dropdown" id="info-dropdown">
        <button class="nav-link info-dropdown__btn" id="info-dropdown-btn" type="button">
          INFORMÁCIE
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="info-dropdown__arrow"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </button>
        <div class="info-dropdown__menu" id="info-dropdown-menu">
          <a href="/legislativa" class="info-dropdown__link">Platná legislatíva</a>
          <a href="/kategorie-vozidiel" class="info-dropdown__link">Kategórie vozidiel</a>
          <a href="/povinna-vybava" class="info-dropdown__link">Povinná výbava</a>
        </div>
      </li>
      {rightNavItems.map(item => (
        <li>
          <a
            href={item.href}
            class:list={['nav-link', { active: currentPath === item.href }]}
            data-translate={item.key}
          >
            {item.label}
          </a>
        </li>
      ))}
      <li>
        <a href="https://www.kontrolavozidiel.sk/rezervovat-cez-internet" class="nav-link btn-rezervovat" data-translate="nav-booking">REZERVOVAŤ</a>
      </li>
    </ul>

    <!-- Social Icons (order: 5) -->
    <div class="navbar-right-extras">
      <div class="social-icons">
        <!-- Facebook -->
        <a href="https://www.facebook.com" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Facebook">
