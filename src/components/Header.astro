  </div>
</div>

<script is:inline>
(function initHeader() {
  var navbar = document.getElementById('navbar');
  var mobileMenuBtn = document.getElementById('mobile-menu-btn');
  var mobileDrawer = document.getElementById('mobile-drawer');
  var mobileDrawerOverlay = document.getElementById('mobile-drawer-overlay');
  var mobileDrawerPanel = document.getElementById('mobile-drawer-panel');
  var mobileCloseBtn = document.getElementById('mobile-close-btn');
  var hamburgerIcon = document.getElementById('hamburger-icon');
  var closeIcon = document.getElementById('close-icon');

  // Scroll effect — transparent → dark blue with blur
  function handleScroll() {
    if (!navbar) return;
    if (window.scrollY > 50) {
      navbar.classList.add('scrolled');
    } else {
      navbar.classList.remove('scrolled');
    }
  }

  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll(); // run on load in case page is already scrolled

  // Info dropdown toggle
  var infoDropdown = document.getElementById('info-dropdown');
  var infoBtn = document.getElementById('info-dropdown-btn');
  if (infoBtn && infoDropdown) {
    infoBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      infoDropdown.classList.toggle('open');
    });
    document.addEventListener('click', () => {
      infoDropdown.classList.remove('open');
    });
  }

  // Mobile drawer open/close
  function openDrawer() {
    if (!mobileDrawer || !mobileDrawerPanel) return;
    mobileDrawer.classList.add('open');
    mobileDrawer.setAttribute('aria-hidden', 'false');
    mobileMenuBtn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
    hamburgerIcon?.classList.add('hidden');
    closeIcon?.classList.remove('hidden');
    // Focus trap: focus the first link in the drawer
    var firstLink = mobileDrawerPanel.querySelector('a, button');
    if (firstLink instanceof HTMLElement) firstLink.focus();
  }

  function closeDrawer() {
    if (!mobileDrawer) return;
    mobileDrawer.classList.remove('open');
    mobileDrawer.setAttribute('aria-hidden', 'true');
    mobileMenuBtn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    hamburgerIcon?.classList.remove('hidden');
    closeIcon?.classList.add('hidden');
  }

  mobileMenuBtn?.addEventListener('click', () => {
    var isOpen = mobileDrawer?.classList.contains('open');
    if (isOpen) {
      closeDrawer();
    } else {
      openDrawer();
    }
  });

  mobileCloseBtn?.addEventListener('click', closeDrawer);
  mobileDrawerOverlay?.addEventListener('click', closeDrawer);

  // Close drawer on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileDrawer?.classList.contains('open')) {
      closeDrawer();
      mobileMenuBtn?.focus();
    }
  });

  // Close drawer when clicking a nav link
  var mobileNavLinks = document.querySelectorAll('.mobile-nav-link');
  mobileNavLinks.forEach(link => {
    link.addEventListener('click', closeDrawer);
  });
})();
document.addEventListener('astro:after-swap', function() {
  // Re-run scroll handler for navbar color
  var nb = document.getElementById('navbar');
  if (nb) {
    function hs() {
      if (window.scrollY > 50) { nb.classList.add('scrolled'); }
      else { nb.classList.remove('scrolled'); }
    }
    window.addEventListener('scroll', hs, { passive: true });
    hs();
  }
  // Re-bind dropdown
  var dd = document.getElementById('info-dropdown');
  var db = document.getElementById('info-dropdown-btn');
  if (db && dd) {
    db.addEventListener('click', function(e) { e.stopPropagation(); dd.classList.toggle('open'); });
    document.addEventListener('click', function() { dd.classList.remove('open'); });
  }
});
</script>

<style>
  /* =====================================================
     NAVBAR — Desktop
     ===================================================== */
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    background: transparent;
    transition: background-color 0.3s ease, backdrop-filter 0.3s ease, box-shadow 0.3s ease;
    overflow: visible;
  }

  .navbar.scrolled {
    background-color: rgba(0, 102, 204, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.15);
  }

  .navbar-inner {
    display: grid;
    grid-template-columns: 84px 1fr auto 1fr 120px;
    align-items: center;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1.25rem;
    height: 64px;
    column-gap: 0.9rem;
  }

  /* =====================================================
     ORDER-BASED LAYOUT
     ===================================================== */
  .navbar-left-extras {
    order: 1;
    width: 84px;
    display: flex;
    justify-content: flex-start;
  }

  .nav-menu-left {
    order: 2;
    justify-self: end;
    justify-content: flex-end;
  }

  .logo {
    order: 3;
    flex-shrink: 0;
    margin: 0 1.5rem;
  }

  .nav-menu-right {
    order: 4;
    justify-self: start;
    justify-content: flex-start;
  }

  .navbar-right-extras {
    order: 5;
    width: 120px;
    display: flex;
    justify-content: flex-end;
  }

  /* =====================================================
     LANGUAGE SWITCHER
     ===================================================== */
  .lang-switcher {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .lang-btn {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 4px;
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.8rem;
    font-weight: 500;
    padding: 0.2rem 0.5rem;
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease;
    line-height: 1;
  }

  .lang-btn:hover {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.6);
  }

  .lang-btn.active {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.7);
  }

  .lang-separator {
    color: rgba(255, 255, 255, 0.3);
    font-size: 0.8rem;
    user-select: none;
  }

  /* =====================================================
     NAV MENUS
     ===================================================== */
  .nav-menu {
    display: flex;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 1.1rem;
  }

  .nav-menu-left {
    display: flex;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 1.1rem;
  }

  .nav-menu-right {
    display: flex;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 1.1rem;
  }

  .nav-link {
    color: #fff;
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    opacity: 0.85;
    transition: opacity 0.2s ease;
    white-space: nowrap;
  }

  .nav-link:hover,
  .nav-link.active {
    opacity: 1;
  }

  /* INFO DROPDOWN */
  .info-dropdown {
    position: relative;
  }

  .info-dropdown__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    background: none;
    border: none;
    font-family: inherit;
    cursor: pointer;
    padding: 0;
  }

  .info-dropdown__arrow {
    transition: transform 0.2s ease;
  }

  .info-dropdown.open .info-dropdown__arrow {
    transform: rotate(180deg);
  }

  .info-dropdown__menu {
    position: absolute;
    top: 100%;
    left: 0;
    margin-top: 0.75rem;
    min-width: 220px;
    background: #0c1d36;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px;
    padding: 0.5rem 0;
    box-shadow: 0 16px 48px rgba(0,0,0,0.5);
    z-index: 99999;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.2s, visibility 0.2s, transform 0.2s;
    pointer-events: none;
  }

  .info-dropdown.open .info-dropdown__menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }

  .info-dropdown__link {
    display: block;
    padding: 0.65rem 1.25rem;
    color: #e2e8f0 !important;
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none !important;
    text-transform: none !important;
    letter-spacing: normal !important;
    transition: background 0.15s;
    white-space: nowrap;
    opacity: 1 !important;
  }

  .info-dropdown__link:hover {
    background: rgba(0, 102, 204, 0.3);
    color: #fff !important;
  }

  .info-dropdown__link::after {
    display: none !important;
  }

  /* REZERVOVAŤ button */
