---
import MainLayout from '@/layouts/MainLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Hero from '@/components/Hero.astro';
import CTASection from '@/components/CTASection.astro';
---

<MainLayout
  title="Cennik | STK JP Control Pezinok"
  description="Cennik sluzbieb STK JP Control Pezinok. Transparentne ceny za technicku kontrolu, emisnu kontrolu a kontrolu originality vozidiel."
  canonical="/cennik"
>
  <Header slot="header" currentPath="/cennik" />

  <Hero
    title="Cenník služieb"
    subtitle="Transparentné ceny pre všetky naše služby"
    ctaText="KONTAKTOVAŤ NÁS"
    ctaHref="/kontakt"
  />

  <!-- Pricing Section -->
  <section class="pricing-section">
    <div class="pricing-container">
      <!-- Intro -->
      <div class="pricing-intro">
        <p>Cenník za služby vykonania technickej kontroly (STK) a emisnej kontroly (EK).</p>
        <p>Cena za opakovanú kontrolu platí iba vtedy, ak bola predchádzajúca kontrola vykonaná na našej STK.</p>
        <p>V prípade nejasností volajte <a href="tel:+421948888088" class="pricing-phone-link">0948 888 088</a>.</p>
      </div>

      <!-- Tab Navigation -->
      <div class="tabs-scroll-container">
        <div class="tabs-nav" role="tablist">
          <button class="tab-btn active" data-tab="common" role="tab" aria-selected="true" aria-controls="panel-common">Najčastejšie vozidlá</button>
          <button class="tab-btn" data-tab="personal" role="tab" aria-selected="false" aria-controls="panel-personal">Osobné vozidlá</button>
          <button class="tab-btn" data-tab="motorcycles" role="tab" aria-selected="false" aria-controls="panel-motorcycles">Motocykle</button>
          <button class="tab-btn" data-tab="trailers" role="tab" aria-selected="false" aria-controls="panel-trailers">Prípojné vozidlá</button>
          <button class="tab-btn" data-tab="trucks" role="tab" aria-selected="false" aria-controls="panel-trucks">Nákladné vozidlá</button>
          <button class="tab-btn" data-tab="tractors" role="tab" aria-selected="false" aria-controls="panel-tractors">Traktory</button>
          <button class="tab-btn" data-tab="other" role="tab" aria-selected="false" aria-controls="panel-other">Ostatné</button>
          <button class="tab-btn" data-tab="extra" role="tab" aria-selected="false" aria-controls="panel-extra">Extra služby</button>
        </div>
      </div>

      <!-- Tab Panels -->

      <!-- TAB 1: Najčastejšie vozidlá -->
      <div class="tab-panel active" id="panel-common" role="tabpanel">
        <h3 class="table-title">Povinná kontrola vyplývajúca zo zákona v SR - najčastejšie vozidlá na našej STK</h3>
        <div class="table-wrapper">
          <table class="pricing-table">
            <tbody>
              <tr>
                <td class="service-cell">Osobné vozidlo (M1, N1) TK+EK</td>
                <td class="price-cell">99 &euro;</td>
              </tr>
              <tr>
                <td class="service-cell">Osobné vozidlo - opakovaná kontrola TK (všetky úkony bez brzdenia vozidla)</td>
                <td class="price-cell">24 &euro;</td>
              </tr>
              <tr>
                <td class="service-cell">Osobné vozidlo - opakovaná kontrola TK (úkony s brzdením vozidla)</td>
                <td class="price-cell">24 &euro;</td>
              </tr>
              <tr>
                <td class="service-cell">Opakovaná kontrola EK (všetky závady týkajúce sa pripojenia OBD)</td>
                <td class="price-cell">24 &euro;</td>
              </tr>
              <tr>
                <td class="service-cell">Opakovaná kontrola EK (všetky závady okrem pripojenia OBD)</td>
                <td class="price-cell">24 &euro;</td>
              </tr>
              <tr>
                <td class="service-cell">Nákladné vozidlo a autobusy (N2,N3, M2, M3) TK+EK</td>
                <td class="price-cell">134 &euro;</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- TAB 2: Osobné vozidlá -->
      <div class="tab-panel" id="panel-personal" role="tabpanel">
        <h3 class="table-title">Osobné vozidlo (M1, N1)</h3>
