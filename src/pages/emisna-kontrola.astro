---
import MainLayout from '@/layouts/MainLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Hero from '@/components/Hero.astro';
import CTASection from '@/components/CTASection.astro';
---

<MainLayout
  title="Emisná kontrola | STK JP Control Pezinok"
  description="Emisná kontrola (EK) motorových vozidiel v STK JP Control Pezinok. Pravidelná, zvláštna, administratívna a opakovaná emisná kontrola pre všetky typy motorov."
  canonical="/emisna-kontrola"
>
  <Header slot="header" currentPath="/emisna-kontrola" />

  <Hero
    title="Emisná kontrola"
    subtitle="Prehliadka a kontrola stavu motora vozidla a jeho emisných systémov"
    ctaText="REZERVOVAŤ TERMÍN"
    ctaHref="https://www.kontrolavozidiel.sk/rezervovat-cez-internet"
    videoSrc="/sluzby.mp4"
  />

  <!-- Čo je emisná kontrola -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-5">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-blue-600 mb-4">Čo je emisná kontrola?</h2>
        <div class="w-16 h-1 bg-blue-600 mx-auto rounded-full"></div>
      </div>
      <div class="space-y-5 text-slate-700 text-lg leading-relaxed max-w-4xl mx-auto">
        <p>Emisnou kontrolou (EK) motorového vozidla je prehliadka a kontrola stavu motora vozidla a jeho systémov, komponentov alebo samostatných technických jednotiek, ktoré ovplyvňujú tvorbu znečisťujúcich látok vo výfukových plynoch, a meraním zistené dodržiavanie podmienok a emisných limitov motora ustanovených vykonávacím právnym predpisom § 136 ods. 3 písm. h). Emisnou kontrolou sa tiež preveruje zhodnosť vozidla so schváleným typom, ak na vozidle bola zistená nezhoda.</p>
        <p>Emisná kontrola sa vykonáva na pracovisku emisnej kontroly podľa jednotlivých druhov kontrol v rozsahu kontrolných úkonov ustanovených <a href="/legislativa" class="text-blue-600 hover:underline">zákonom č. 106/2018 Z. z.</a> o prevádzke vozidiel v cestnej premávke, vykonávacím právnym predpisom podľa § 136 ods. 3 písm. h) a podľa metodík vydaných typovým schvaľovacím orgánom.</p>
      </div>
    </div>
  </section>

  <!-- Druhy emisných kontrol -->
  <section class="py-16 bg-slate-50">
    <div class="max-w-5xl mx-auto px-5">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-blue-600 mb-4">Druhy emisných kontrol</h2>
        <div class="w-16 h-1 bg-blue-600 mx-auto rounded-full"></div>
        <p class="text-slate-500 mt-4 max-w-2xl mx-auto">Druhy emisných kontrol, ktoré vykonávame:</p>
      </div>
      <div class="space-y-6 max-w-4xl mx-auto">
        <div class="bg-white rounded-2xl p-6 border border-slate-200 shadow-sm">
          <h3 class="text-xl font-bold text-blue-600 mb-3">Emisná kontrola PRAVIDELNÁ</h3>
          <p class="text-slate-700 leading-relaxed">Vykonáva sa v rozsahu kontrolných položiek určených metodickými pokynmi ministerstva dopravy na vykonávanie emisnej kontroly pravidelnej.</p>
        </div>

        <div class="bg-white rounded-2xl p-6 border border-slate-200 shadow-sm">
          <h3 class="text-xl font-bold text-blue-600 mb-3">Emisná kontrola ZVLÁŠTNA</h3>
          <p class="text-slate-700 leading-relaxed">Vykonáva sa v úplnom alebo čiastočnom rozsahu emisnej kontroly pravidelnej a podľa kontrolných položiek určených metodikou na vykonávanie emisných kontrol zvláštnych.</p>
        </div>

        <div class="bg-white rounded-2xl p-6 border border-slate-200 shadow-sm">
          <h3 class="text-xl font-bold text-blue-600 mb-3">Emisná kontrola ADMINISTRATÍVNA</h3>
          <p class="text-slate-700 leading-relaxed">Vykonáva sa v čiastočnom rozsahu emisnej kontroly pravidelnej a podľa kontrolných položiek určených metodikou na vykonávanie emisných kontrol administratívnych.</p>
        </div>

        <div class="bg-white rounded-2xl p-6 border border-slate-200 shadow-sm">
          <h3 class="text-xl font-bold text-blue-600 mb-3">OPAKOVANÁ emisná kontrola</h3>
          <p class="text-slate-700 leading-relaxed">Vykonáva sa v plnom rozsahu pôvodnej emisnej kontroly s dôrazom na kontrolu odstránenia chýb zistených pri emisnej kontrole uvedenej v predchádzajúcich bodoch, a to do 60 dní odo dňa vykonania pôvodnej kontroly.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Kategórie vozidiel -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-5">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-blue-600 mb-4">Kategórie vozidiel</h2>
        <div class="w-16 h-1 bg-blue-600 mx-auto rounded-full"></div>
        <p class="text-slate-500 mt-4 max-w-2xl mx-auto">Kategórie vozidiel, pre ktoré vykonávame emisné kontroly:</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-4xl mx-auto">
        <div class="bg-blue-50 rounded-xl p-5 border border-blue-100 flex items-center gap-4">
          <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          </div>
          <p class="text-slate-700">so zážihovým (benzínovým) motorom s nezdokonaleným emisným systémom (BEZKAT/NKAT)</p>
        </div>
        <div class="bg-blue-50 rounded-xl p-5 border border-blue-100 flex items-center gap-4">
          <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          </div>
          <p class="text-slate-700">so zážihovým (benzínovým) motorom so zdokonaleným emisným systémom (RKAT)</p>
        </div>
        <div class="bg-blue-50 rounded-xl p-5 border border-blue-100 flex items-center gap-4">
          <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          </div>
          <p class="text-slate-700">so zážihovým (benzínovým) motorom so zdokonaleným emisným systémom (RKAT), ktoré je vybavené systémom palubnej diagnostiky OBD (RKAT OBD)</p>
        </div>
        <div class="bg-blue-50 rounded-xl p-5 border border-blue-100 flex items-center gap-4">
          <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          </div>
          <p class="text-slate-700">so vznetovým (naftovým) motorom</p>
        </div>
        <div class="bg-blue-50 rounded-xl p-5 border border-blue-100 flex items-center gap-4">
          <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          </div>
          <p class="text-slate-700">so vznetovým (naftovým) motorom, ktoré je vybavené systémom palubnej diagnostiky OBD</p>
        </div>
        <div class="bg-blue-50 rounded-xl p-5 border border-blue-100 flex items-center gap-4">
          <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          </div>
          <p class="text-slate-700">s hybridným pohonom</p>
        </div>
        <div class="bg-blue-50 rounded-xl p-5 border border-blue-100 flex items-center gap-4 sm:col-span-2 sm:max-w-md sm:mx-auto">
          <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          </div>
          <p class="text-slate-700">s pohonom LPG/CNG</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Aké vozidlá podliehajú / nepodliehajú EK -->
  <section class="py-16 bg-slate-50">
    <div class="max-w-5xl mx-auto px-5">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-blue-600 mb-4">Aké vozidlá podliehajú vykonaniu pravidelnej emisnej kontroly?</h2>
        <div class="w-16 h-1 bg-blue-600 mx-auto rounded-full"></div>
      </div>
      <div class="max-w-4xl mx-auto space-y-8">
        <div class="bg-white rounded-2xl p-6 border border-slate-200 shadow-sm">
          <ul class="space-y-3 text-slate-600">
            <li class="flex gap-3 items-start"><span class="text-blue-600 mt-1 shrink-0">&#9679;</span><span>motorové vozidlo, ktoré je evidované v Slovenskej republike a nie je dočasne vyradené z evidencie vozidiel; to neplatí pre jednotlivé vozidlo s obmedzenou prevádzkou,</span></li>
            <li class="flex gap-3 items-start"><span class="text-blue-600 mt-1 shrink-0">&#9679;</span><span>jednotlivo dovezené motorové vozidlo z členského štátu alebo zmluvného štátu, ktoré nemá platný doklad o vykonaní emisnej kontroly, pred jeho prihlásením do evidencie vozidiel v Slovenskej republike,</span></li>
            <li class="flex gap-3 items-start"><span class="text-blue-600 mt-1 shrink-0">&#9679;</span><span>jednotlivo dovezené motorové vozidlo z tretieho štátu pred jeho prihlásením do evidencie vozidiel v Slovenskej republike,</span></li>
            <li class="flex gap-3 items-start"><span class="text-blue-600 mt-1 shrink-0">&#9679;</span><span>opätovne schvaľované jednotlivé motorové vozidlo,</span></li>
            <li class="flex gap-3 items-start"><span class="text-blue-600 mt-1 shrink-0">&#9679;</span><span>dodatočne schvaľované jednotlivé motorové vozidlo,</span></li>
            <li class="flex gap-3 items-start"><span class="text-blue-600 mt-1 shrink-0">&#9679;</span><span>motorové vozidlo pri výmene technického osvedčenia vozidla.</span></li>
          </ul>
        </div>

        <div class="text-center">
          <h3 class="text-2xl font-bold text-blue-600 mb-4">Aké vozidlá nepodliehajú vykonaniu pravidelnej emisnej kontroly?</h3>
          <div class="w-16 h-1 bg-blue-600 mx-auto rounded-full"></div>
        </div>
        <div class="bg-white rounded-2xl p-6 border border-slate-200 shadow-sm">
          <ul class="space-y-3 text-slate-600">
            <li class="flex gap-3 items-start"><span class="text-blue-600 mt-1 shrink-0">&#9679;</span><span>motorové vozidlo so zážihovým (benzínovým) motorom mazané zmesou paliva a mazacieho oleja,</span></li>
            <li class="flex gap-3 items-start"><span class="text-blue-600 mt-1 shrink-0">&#9679;</span><span>motorové vozidlo so zážihovým (benzínovým) motorom prihláseným do evidencie vozidiel pred 01.08.1970,</span></li>
            <li class="flex gap-3 items-start"><span class="text-blue-600 mt-1 shrink-0">&#9679;</span><span>motorové vozidlo so vznetovým (naftovým) motorom prihláseným do evidencie vozidiel pred 01.12.1971,</span></li>
            <li class="flex gap-3 items-start"><span class="text-blue-600 mt-1 shrink-0">&#9679;</span><span>malé motocykle do 50 cm3 (L1e), malé trojkolky do 50 cm3 (L2e), malé prípojné vozidlá do 750 kilogramov (O1) a malé prípojné vozidlá za traktor do 1 500 kg (R1).</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Čo sa kontroluje pri EK -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-5">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-blue-600 mb-4">Čo sa kontroluje pri emisnej kontrole?</h2>
        <div class="w-16 h-1 bg-blue-600 mx-auto rounded-full"></div>
        <p class="text-slate-500 mt-4 max-w-2xl mx-auto">Kontrola sa zameriava prinajmenšom na nasledujúce oblasti:</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        <div class="bg-slate-50 rounded-2xl p-5 border border-slate-200">
          <h3 class="text-lg font-bold text-blue-600 mb-3">Identifikácia vozidla</h3>
          <ul class="space-y-1 text-slate-600 text-sm">
            <li class="flex gap-2 items-start"><span class="text-blue-600 shrink-0">&#8226;</span><span>tabuľky s evidenčným číslom – ak sa v požiadavkách vyžadujú,</span></li>
            <li class="flex gap-2 items-start"><span class="text-blue-600 shrink-0">&#8226;</span><span>identifikačné číslo vozidla / podvozku / výrobné číslo,</span></li>
          </ul>
        </div>

        <div class="bg-slate-50 rounded-2xl p-5 border border-slate-200">
          <h3 class="text-lg font-bold text-blue-600 mb-3">Svietidlá, odrazové sklá a elektrické zariadenie</h3>
          <ul class="space-y-1 text-slate-600 text-sm">
            <li class="flex gap-2 items-start"><span class="text-blue-600 shrink-0">&#8226;</span><span>elektrické vedenie,</span></li>
            <li class="flex gap-2 items-start"><span class="text-blue-600 shrink-0">&#8226;</span><span>akumulátor (batérie),</span></li>
          </ul>
        </div>

        <div class="bg-slate-50 rounded-2xl p-5 border border-slate-200">
          <h3 class="text-lg font-bold text-blue-600 mb-3">Podvozok a jeho príslušenstvo</h3>
          <ul class="space-y-1 text-slate-600 text-sm">
            <li class="flex gap-2 items-start"><span class="text-blue-600 shrink-0">&#8226;</span><span>podvozok alebo rám a príslušenstvo – výfukové potrubie a tlmiče, palivová nádrž a potrubie (vrátane palivovej nádrže a potrubia na vykurovanie), výkon motora (X),</span></li>
          </ul>
        </div>

        <div class="bg-slate-50 rounded-2xl p-5 border border-slate-200">
          <h3 class="text-lg font-bold text-blue-600 mb-3">Zaťaženie životného prostredia</h3>
          <ul class="space-y-1 text-slate-600 text-sm">
            <li class="flex gap-2 items-start"><span class="text-blue-600 shrink-0">&#8226;</span><span>emisie výfukových plynov,</span></li>
            <li class="flex gap-2 items-start"><span class="text-blue-600 shrink-0">&#8226;</span><span>úniky kvapalín,</span></li>
          </ul>
        </div>

        <div class="bg-slate-50 rounded-2xl p-5 border border-slate-200 md:col-span-2 md:max-w-md md:mx-auto">
          <h3 class="text-lg font-bold text-blue-600 mb-3">Doplňujúce skúšky pre vozidlá kategórií M2, M3 určené na prepravu osôb</h3>
          <ul class="space-y-1 text-slate-600 text-sm">
            <li class="flex gap-2 items-start"><span class="text-blue-600 shrink-0">&#8226;</span><span>systém vetrania a kúrenia (X),</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Aké doklady treba predložiť na EK -->
  <section class="py-16 bg-slate-50">
    <div class="max-w-5xl mx-auto px-5">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-blue-600 mb-4">Aké doklady treba predložiť na emisnú kontrolu (EK)?</h2>
        <div class="w-16 h-1 bg-blue-600 mx-auto rounded-full"></div>
        <p class="text-slate-500 mt-4 max-w-2xl mx-auto">Prevádzkovateľ vozidla alebo vodič vozidla predkladá na vykonanie:</p>
      </div>
      <div class="space-y-6 max-w-4xl mx-auto">
        <div class="bg-white rounded-2xl p-6 border border-slate-200 shadow-sm">
          <h3 class="text-lg font-bold text-blue-600 mb-4">EK pravidelnej, EK zvláštnej a EK administratívnej:</h3>
          <ul class="space-y-3 text-slate-600">
            <li class="flex gap-3 items-start"><span class="text-blue-600 mt-1 shrink-0">&#9679;</span><span>doklad vozidla (osvedčenie o evidencii časť I alebo časť II alebo technické osvedčenie vozidla pri vozidle, ktoré nepodlieha prihláseniu do evidencie vozidiel) alebo potvrdenie o zadržaní, ak ide o vozidlo, ktorému je doklad vozidla zadržaný, alebo výpis z karty vozidla vydaný orgánom Policajného zboru, ak je doklad vozidla stratený,</span></li>
            <li class="flex gap-3 items-start"><span class="text-blue-600 mt-1 shrink-0">&#9679;</span><span>protokol o montáži plynového zariadenia, ak ide o vozidlo s pohonom na skvapalnený ropný plyn (LPG) alebo s pohonom na zemný plyn (CNG), ak montáž plynového zariadenia je vykonaná v rámci prestavby vozidla,</span></li>
            <li class="flex gap-3 items-start">
              <span class="text-blue-600 mt-1 shrink-0">&#9679;</span>
              <div>
                <span>protokol o inšpekcii CNG, LNG nádrže:</span>
                <ul class="list-disc list-inside ml-4 mt-2 space-y-1 text-sm">
                  <li>nádrž na CNG podlieha inšpekcii, ak uplynuli 4 roky od prvej evidencie vozidla a potom periodicky v 4-ročných intervaloch,</li>
                  <li>nádrž na LNG podlieha inšpekcii, ak uplynul rok od prvej evidencie vozidla a potom periodicky v ročných intervaloch,</li>
                </ul>
              </div>
            </li>
            <li class="flex gap-3 items-start"><span class="text-blue-600 mt-1 shrink-0">&#9679;</span><span>osvedčenie o schválení jednotlivo dovezeného vozidla a základný technický opis vozidla vydaný schvaľovacím orgánom, ak ide o emisnú kontrolu administratívnu jednotlivo dovezeného vozidla, ktoré má byť podrobené takej kontrole v lehote do 15 dní od prihlásenia vozidla do evidencie vozidiel a prevádzkovateľ pri schvaľovaní jednotlivo dovezeného vozidla predložil doklad o vykonaní EK pravidelnej v členskom štáte alebo zmluvnom štáte,</span></li>
            <li class="flex gap-3 items-start"><span class="text-blue-600 mt-1 shrink-0">&#9679;</span><span>potvrdenie o vykonanej dezinfekcii vozidla, ak ide o vozidlo záchrannej služby určeného na prepravu infekčných materiálov alebo pacientov s infekčnými chorobami, vozidlo určeného na prepravu uhynutých zvierat a vozidlo pohrebnej služby.</span></li>
          </ul>
        </div>

        <div class="bg-white rounded-2xl p-6 border border-slate-200 shadow-sm">
          <h3 class="text-lg font-bold text-blue-600 mb-4">Opakovanej EK:</h3>
          <ul class="space-y-2 text-slate-600">
            <li class="flex gap-3 items-start"><span class="text-blue-600 mt-1 shrink-0">&#9679;</span><span>doklady pre príslušný druh emisnej kontroly (už spomenuté v odseku a)),</span></li>
          </ul>
        </div>

        <div class="bg-white rounded-2xl p-6 border border-slate-200 shadow-sm">
          <h3 class="text-lg font-bold text-blue-600 mb-4">EK pravidelnej – v súvislosti s vydaním nového dokladu vozidla po hromadnej prestavbe:</h3>
          <ul class="space-y-2 text-slate-600">
            <li class="flex gap-3 items-start"><span class="text-blue-600 mt-1 shrink-0">&#9679;</span><span>doklady spomenuté v odseku a),</span></li>
            <li class="flex gap-3 items-start"><span class="text-blue-600 mt-1 shrink-0">&#9679;</span><span>doklad o vykonaní hromadnej prestavby,</span></li>
            <li class="flex gap-3 items-start"><span class="text-blue-600 mt-1 shrink-0">&#9679;</span><span>kópia schválenia hromadnej prestavby vrátane kópie základného technického opisu vozidla,</span></li>
          </ul>
        </div>

        <div class="bg-white rounded-2xl p-6 border border-slate-200 shadow-sm">
          <h3 class="text-lg font-bold text-blue-600 mb-4">EK pravidelnej – z dôvodu povolenia výnimky z technických požiadaviek:</h3>
          <ul class="space-y-2 text-slate-600">
            <li class="flex gap-3 items-start"><span class="text-blue-600 mt-1 shrink-0">&#9679;</span><span>doklady spomenuté v odseku a),</span></li>
            <li class="flex gap-3 items-start"><span class="text-blue-600 mt-1 shrink-0">&#9679;</span><span>opis žiadanej výnimky,</span></li>
          </ul>
        </div>

        <div class="bg-white rounded-2xl p-6 border border-slate-200 shadow-sm">
