---
import MainLayout from '@/layouts/MainLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Hero from '@/components/Hero.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import CTASection from '@/components/CTASection.astro';
import AnnouncementBar from '@/components/AnnouncementBar.astro';
import AnimatedServiceIcons from '@/components/AnimatedServiceIcons.astro';
---

<MainLayout
  title="STK JP Control Pezinok | Technická kontrola, Emisná kontrola, Kontrola originality"
  description="STK JP Control - Vaša spoľahlivá stanica technickej kontroly v Pezinku. Technické kontroly, emisné kontroly a kontroly originality. Online rezervácia termínu."
  canonical="/"
>
  <Header slot="header" currentPath="/" />
  <AnnouncementBar slot="announcement" />

  <Hero />

  <!-- Výhody u nás -->
  <section id="advantages" class="advantages-section animate-on-scroll animate-fade-up wave-separator-top wave-separator-bottom">
    <div class="advantages-container">
      <div class="advantages-header">
        <h2 class="advantages-title gradient-text">Výhody u nás</h2>
        <div class="advantages-divider"></div>
        <p class="advantages-subtitle">Prečo si vybrať práve nás</p>
      </div>

      <div class="advantages-grid">
        <div class="advantage-card" style="background-image: url('/images/about-hero-1.jpg')">
          <div class="advantage-card__content">
            <h3 class="advantage-card__title">Odvoz/dovoz zadarmo</h3>
            <p class="advantage-card__text">Ak sa potrebujete počas kontroly nečakane dostaviť na neplánované stretnutie, vieme Vám zabezpečiť odvoz aj dovoz k nám. (do 10 km)</p>
            <span class="advantage-card__cta">STK bez stresu</span>
          </div>
        </div>

        <div class="advantage-card" style="background-image: url('/images/about-hero-2.jpg')">
          <div class="advantage-card__content">
            <h3 class="advantage-card__title">Prídeme si pre Vaše vozidlo</h3>
            <p class="advantage-card__text">Nemôžete sa k nám osobne dostaviť na kontrolu? Prídeme si po Vaše vozidlo a po kontrole Vám ho privezieme späť. (do 10 km)</p>
            <span class="advantage-card__cta">Bezstarostná preprava</span>
          </div>
        </div>

        <div class="advantage-card" style="background-image: url('/images/automat.png')">
          <div class="advantage-card__content">
            <h3 class="advantage-card__title">NONSTOP pre nákladné vozidlá</h3>
            <p class="advantage-card__text">Po telefonickej objednávke aj mimo otváracích hodín. BEZ PRÍPLATKU</p>
            <span class="advantage-card__cta">Servis aj po 22:00</span>
          </div>
        </div>

        <div class="advantage-card" style="background-image: url('/images/hero-poster.jpg')">
          <div class="advantage-card__content">
            <h3 class="advantage-card__title">Zapožičanie prevozných ŠPZ</h3>
            <p class="advantage-card__text">Pre potreby KO a STK v rámci SR</p>
            <span class="advantage-card__cta">Dokončené rýchlejšie</span>
          </div>
        </div>

        <div class="advantage-card" style="background-image: url('/images/nabijacka.png')">
          <div class="advantage-card__content">
            <h3 class="advantage-card__title">Nabíjacia stanica</h3>
            <p class="advantage-card__text">U nás si počas čakania dobijete svoje elektroauto pohodlne v areáli stanice.</p>
            <span class="advantage-card__cta">Komfort pri čakaní</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- O nás -->
  <section id="o-nas" class="py-20 bg-white wave-separator-bottom wave-gray">
    <div class="max-w-7xl mx-auto px-5">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-primary mb-4 gradient-text" data-translate="section-about">O nás</h2>
        <div class="w-16 h-1 bg-primary rounded mb-10 mx-auto"></div>
      </div>

      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <div class="space-y-5">
          <p class="text-gray-700 leading-relaxed text-lg">
            Spoločnosť JP Control s.r.o. je mladá dynamická spoločnosť, pôsobiaca v oblasti služieb
            spojených s registráciou vozidiel, kontrolami originality, emisnými kontrolami
            a technickými kontrolami vozidiel.
          </p>
          <p class="text-gray-700 leading-relaxed text-lg">
            Pracujeme s moderným technologickým vybavením, ktoré sa s našimi bohatými skúsenosťami
            a odbornými znalosťami podpisuje pod dôslednú kontrolu.
          </p>
          <p class="text-gray-700 leading-relaxed text-lg">
            V záujme dosahovania a zachovania vysokého kvalitatívneho štandardu má spoločnosť
            JP Control s.r.o. zavedený systém manažérstva kvality v zmysle požiadaviek normy
            ISO 9001:2015 a normy ISO 37001:2016.
          </p>
          <p class="text-gray-700 leading-relaxed text-lg font-semibold">
            Garantujeme spoľahlivosť, zodpovednosť, flexibilitu a precíznosť.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 gap-5">
          <!-- ISO 9001:2015 -->
          <div class="bg-gray-50 border border-gray-100 rounded-2xl p-6 text-center hover:shadow-lg transition-shadow duration-300">
            <div class="w-14 h-14 bg-primary-light rounded-xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="font-bold text-primary text-lg mb-1">ISO 9001:2015</h3>
            <p class="text-gray-500 text-sm">Systém manažérstva kvality</p>
          </div>

          <!-- ISO 37001:2016 -->
          <div class="bg-gray-50 border border-gray-100 rounded-2xl p-6 text-center hover:shadow-lg transition-shadow duration-300">
            <div class="w-14 h-14 bg-primary-light rounded-xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="font-bold text-primary text-lg mb-1">ISO 37001:2016</h3>
            <p class="text-gray-500 text-sm">Systém protikorupčného manažérstva</p>
          </div>

          <!-- Moderné vybavenie -->
          <div class="bg-gray-50 border border-gray-100 rounded-2xl p-6 text-center hover:shadow-lg transition-shadow duration-300">
            <div class="w-14 h-14 bg-primary-light rounded-xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="font-bold text-primary text-lg mb-1">Moderné vybavenie</h3>
            <p class="text-gray-500 text-sm">Najnovšie technológie kontroly</p>
          </div>

          <!-- NONSTOP telefón -->
          <div class="bg-gray-50 border border-gray-100 rounded-2xl p-6 text-center hover:shadow-lg transition-shadow duration-300">
            <div class="w-14 h-14 bg-primary-light rounded-xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <h3 class="font-bold text-primary text-lg mb-1">NONSTOP telefón</h3>
            <p class="text-gray-500 text-sm">Vždy sa nám dovoláte</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Ako prebieha kontrola? -->
  <section id="proces" class="process-section animate-on-scroll animate-fade-up">
    <div class="process-container">
      <div class="process-header">
        <h2 class="process-title gradient-text">Ako prebieha kontrola?</h2>
        <div class="process-divider"></div>
        <p class="process-subtitle">Jednoduchý proces v 4 krokoch</p>
      </div>

      <div class="process-timeline" id="process-timeline">
        <div class="process-line-bg"></div>
        <div class="process-line-fill" id="process-line-fill"></div>

        <div class="process-step" data-step="1">
          <div class="process-step__circle">
            <span class="process-step__emoji">&#128197;</span>
          </div>
          <h3 class="process-step__title">Rezervácia</h3>
          <p class="process-step__desc">Rezervujte si termín online alebo telefonicky</p>
        </div>

        <div class="process-step" data-step="2">
          <div class="process-step__circle">
            <span class="process-step__emoji">&#128663;</span>
          </div>
          <h3 class="process-step__title">Príchod</h3>
          <p class="process-step__desc">Pristaviť vozidlo na naše pracovisko</p>
        </div>

        <div class="process-step" data-step="3">
          <div class="process-step__circle">
            <span class="process-step__emoji">&#128295;</span>
          </div>
          <h3 class="process-step__title">Kontrola</h3>
          <p class="process-step__desc">Profesionálna kontrola certifikovanými technikmi</p>
        </div>

        <div class="process-step" data-step="4">
          <div class="process-step__circle">
            <span class="process-step__emoji">&#9989;</span>
          </div>
          <h3 class="process-step__title">Hotovo</h3>
          <p class="process-step__desc">Prevzatie dokladov a vozidla</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Naše služby -->
  <section id="sluzby" class="py-20 bg-gray-50 wave-separator-top wave-gray dotted-grid-bg">
    <div class="max-w-7xl mx-auto px-5">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-primary mb-4 gradient-text" data-translate="section-services">Naše služby</h2>
        <div class="w-16 h-1 bg-primary rounded mb-10 mx-auto"></div>
        <p class="text-gray-600 text-lg max-w-2xl mx-auto">
          Poskytujeme kompletné služby technickej a emisnej kontroly vozidiel
          s profesionálnym prístupom a moderným vybavením.
        </p>
      </div>

      <AnimatedServiceIcons />

      <div class="grid md:grid-cols-3 gap-8">
        <ServiceCard
          title="Technická kontrola"
          description="Pravidelná technická kontrola vozidla podľa platnej legislatívy. Kontrolujeme brzdovú sústavu, podvozok, osvetlenie, koróziu a ďalšie dôležité komponenty vášho vozidla."
          image="/images/TK.png"
          badge="Technická kontrola"
          href="/technicka-kontrola"
        />
        <ServiceCard
          title="Emisná kontrola"
          description="Emisná kontrola zisťuje, či motor vášho vozidla spĺňa emisné limity stanovené zákonom. Kontrolujeme zloženie výfukových plynov benzínových aj naftových motorov."
          image="/images/EK.png"
          badge="Emisná kontrola"
          href="/emisna-kontrola"
        />
        <ServiceCard
          title="Kontrola originality"
          description="Kontrola originality overuje identitu vozidla a zisťuje, či neboli pozmenené identifikátory ako VIN číslo, výrobné štítky alebo iné označenia vozidla."
          image="/images/KO.png"
          badge="Kontrola originality"
          href="/kontrola-originality"
        />
      </div>
    </div>
  </section>

  <!-- Otváracie hodiny -->
  <section class="py-20 bg-white wave-separator-top">
    <div class="max-w-7xl mx-auto px-5">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-primary mb-4 gradient-text" data-translate="section-hours">Otváracie hodiny</h2>
        <div class="w-16 h-1 bg-primary rounded mb-10 mx-auto"></div>
      </div>

      <div class="max-w-lg mx-auto">
        <div class="bg-gray-50 border border-gray-100 rounded-2xl overflow-hidden shadow-sm">
          <div class="bg-primary px-8 py-5">
            <h3 class="text-white text-xl font-semibold text-center flex items-center justify-center gap-3">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Otváracie hodiny
            </h3>
          </div>

          <div class="divide-y divide-gray-100">
            <!-- Pondelok -->
            <div class="flex items-center justify-between px-8 py-4">
              <span class="font-medium text-gray-800" data-translate="day-mon">Pondelok</span>
              <span class="font-semibold text-primary text-lg">6:00 – 19:00</span>
            </div>

            <!-- Utorok -->
            <div class="flex items-center justify-between px-8 py-4 bg-white">
              <span class="font-medium text-gray-800" data-translate="day-tue">Utorok</span>
              <span class="font-semibold text-primary text-lg">6:00 – 16:00</span>
            </div>

            <!-- Streda -->
            <div class="flex items-center justify-between px-8 py-4">
              <span class="font-medium text-gray-800" data-translate="day-wed">Streda</span>
              <span class="font-semibold text-primary text-lg">6:00 – 16:00</span>
            </div>

            <!-- Štvrtok -->
            <div class="flex items-center justify-between px-8 py-4 bg-white">
              <span class="font-medium text-gray-800" data-translate="day-thu">Štvrtok</span>
              <span class="font-semibold text-primary text-lg">6:00 – 16:00</span>
            </div>

            <!-- Piatok -->
            <div class="flex items-center justify-between px-8 py-4">
              <span class="font-medium text-gray-800" data-translate="day-fri">Piatok</span>
              <span class="font-semibold text-primary text-lg">6:00 – 16:00</span>
            </div>

            <!-- Sobota -->
            <div class="flex items-center justify-between px-8 py-4 bg-white">
              <span class="font-medium text-gray-800" data-translate="day-sat">Sobota</span>
              <span class="text-red-500 font-semibold text-lg" data-translate="closed">Zatvorené</span>
            </div>

            <!-- Nedeľa -->
            <div class="flex items-center justify-between px-8 py-4">
              <span class="font-medium text-gray-800" data-translate="day-sun">Nedeľa</span>
              <span class="text-red-500 font-semibold text-lg" data-translate="closed">Zatvorené</span>
            </div>
          </div>

          <div class="bg-primary/5 px-8 py-4 text-center">
            <p class="text-sm text-gray-600">
              <span class="font-semibold text-primary">NONSTOP telefón</span> – kontaktujte nás kedykoľvek
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Recenzie -->
  <section id="reviews" class="reviews-section animate-on-scroll animate-fade-up wave-separator-top wave-separator-bottom">
    <div class="reviews-container">
      <div class="reviews-header">
        <h2 class="reviews-title gradient-text">Napísali o nás</h2>
        <div class="reviews-divider"></div>
        <p class="reviews-subtitle">Recenzie našich zákazníkov</p>
      </div>

      <div class="reviews-carousel" id="reviews-carousel">
        <button class="carousel-arrow carousel-arrow--prev" id="carousel-prev" aria-label="Predchádzajúca recenzia">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>

        <div class="carousel-track-wrapper">
          <div class="carousel-track" id="carousel-track">
            <div class="review-card carousel-slide" data-slide="0">
              <div class="review-card__stars">
                <span class="review-star">&#9733;</span>
                <span class="review-star">&#9733;</span>
                <span class="review-star">&#9733;</span>
                <span class="review-star">&#9733;</span>
                <span class="review-star">&#9733;</span>
              </div>
              <p class="review-card__text">"Za mňa zatiaľ najlepšia Emisná a STK na akej som bola príjemný prístup dievčat a pani ktorá tam bola a stále nám ponúkala bud koláčik raňajky kávu ..."</p>
              <p class="review-card__author">Kristina Martinková</p>
            </div>

            <div class="review-card carousel-slide" data-slide="1">
              <div class="review-card__stars">
                <span class="review-star">&#9733;</span>
                <span class="review-star">&#9733;</span>
                <span class="review-star">&#9733;</span>
                <span class="review-star">&#9733;</span>
                <span class="review-star">&#9733;</span>
              </div>
              <p class="review-card__text">"Veľmi príjemný zážitok. Bol som prvý krát na odporúčanie a som milo prekvapený. Prakticky o nič sa nemusíte starať, dostanete aj kávičku a štrúdlu v ..."</p>
              <p class="review-card__author">dwarfiusislav</p>
            </div>

            <div class="review-card carousel-slide" data-slide="2">
              <div class="review-card__stars">
                <span class="review-star">&#9733;</span>
                <span class="review-star">&#9733;</span>
                <span class="review-star">&#9733;</span>
                <span class="review-star">&#9733;</span>
                <span class="review-star">&#9733;</span>
              </div>
              <p class="review-card__text">"EK a STK No lepšie sme ani nemohli spraviť ako ísť zrovna sem ..... 10/10 od vstupu až po odchod ..... Takýto servis som ešte nikde nezažil od ..."</p>
              <p class="review-card__author">CHRÁNIME TO ČO MUSÍME</p>
            </div>
          </div>
        </div>

        <button class="carousel-arrow carousel-arrow--next" id="carousel-next" aria-label="Nasledujúca recenzia">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
      </div>

      <div class="carousel-dots" id="carousel-dots">
        <button class="carousel-dot active" data-dot="0" aria-label="Recenzia 1"></button>
        <button class="carousel-dot" data-dot="1" aria-label="Recenzia 2"></button>
        <button class="carousel-dot" data-dot="2" aria-label="Recenzia 3"></button>
      </div>
    </div>
  </section>

  <!-- Special Offer CTA -->
  <section class="special-offer-section animate-on-scroll animate-fade-up">
    <div class="special-offer-container">
      <h2 class="special-offer-title">Prihlásenie Vášho vozidla až po EČV!</h2>
      <p class="special-offer-subtitle">Kompletná služba pre vaše vozidlo</p>
      <a href="/kontakt" class="special-offer-btn pulse-glow">Chcem vedieť viac!</a>
    </div>
  </section>

  <!-- Dobíjanie elektromobilov -->
  <section id="charging" class="charging-section animate-on-scroll animate-fade-up">
    <div class="charging-container">
      <div class="charging-header">
        <h2 class="charging-title gradient-text">Dobíjanie elektromobilov</h2>
        <div class="charging-divider"></div>
        <p class="charging-subtitle">Rýchle a pohodlné dobíjanie vášho elektromobilu</p>
      </div>

      <div class="charging-card">
        <div class="charging-card__image">
          <img src="/images/nabijacka.png" alt="Dobíjacia stanica pre elektromobily" loading="lazy" />
        </div>
        <div class="charging-card__info">
          <h3 class="charging-card__title">Dobíjacia stanica</h3>
          <p class="charging-card__desc">Naša STK je vybavená modernou dobíjacou stanicou pre elektromobily. Počas čakania na kontrolu môžete pohodlne dobiť svoje vozidlo.</p>
          <ul class="charging-card__features">
            <li class="charging-card__feature">
              <svg class="charging-card__icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              Rýchle dobíjanie
            </li>
            <li class="charging-card__feature">
              <svg class="charging-card__icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              Dostupné počas otváracích hodín
            </li>
            <li class="charging-card__feature">
              <svg class="charging-card__icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              Kontaktujte nás pre ceny
            </li>
          </ul>
          <a href="/kontakt" class="charging-card__btn">Kontaktovať</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Doplnkové služby -->
