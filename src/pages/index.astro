<script is:inline>
// Reviews Carousel (multi-card)
(function() {
  var track = document.getElementById('carousel-track');
  var dotsWrap = document.getElementById('carousel-dots');
  var prevBtn = document.getElementById('carousel-prev');
  var nextBtn = document.getElementById('carousel-next');
  var carousel = document.getElementById('reviews-carousel');
  if (!track || !prevBtn || !nextBtn || !carousel || !dotsWrap) return;

  var current = 0;
  var total = track.children.length;
  var visible = 3;
  var maxIndex = 0;
  var autoInterval = null;

  function getVisibleCount() {
    if (window.innerWidth <= 640) return 1;
    if (window.innerWidth <= 1100) return 2;
    return 3;
  }

  function normalizeText(text) {
    if (!text || typeof text !== 'string') return '';
    return text.length > 180 ? text.slice(0, 177).trim() + '...' : text;
  }

  function buildSlide(item) {
    var card = document.createElement('article');
    card.className = 'review-card carousel-slide';

    var stars = document.createElement('div');
    stars.className = 'review-card__stars';
    var rating = Math.max(1, Math.min(5, Number(item.rating) || 5));
    for (var i = 0; i < 5; i += 1) {
      var star = document.createElement('span');
      star.className = 'review-star';
      star.innerHTML = i < rating ? '&#9733;' : '&#9734;';
      stars.appendChild(star);
    }

    var text = document.createElement('p');
    text.className = 'review-card__text';
    text.textContent = '"' + normalizeText(item.text || '') + '"';

    var author = document.createElement('p');
    author.className = 'review-card__author';
    author.textContent = item.author_name || 'Zákazník';

    card.appendChild(stars);
    card.appendChild(text);
    card.appendChild(author);
    return card;
  }

  function refreshCounts() {
    total = track.children.length;
    visible = Math.min(getVisibleCount(), Math.max(1, total));
    carousel.style.setProperty('--visible-count', String(visible));
    maxIndex = Math.max(0, total - visible);
    if (current > maxIndex) current = maxIndex;
  }

  function renderDots() {
    dotsWrap.innerHTML = '';
    var pages = Math.max(1, maxIndex + 1);
    for (var i = 0; i < pages; i += 1) {
      var dot = document.createElement('button');
      dot.className = 'carousel-dot' + (i === current ? ' active' : '');
      dot.setAttribute('aria-label', 'Recenzia ' + (i + 1));
      dot.addEventListener('click', (function(index) {
        return function() {
          goTo(index, false);
          startAuto();
        };
      })(i));
      dotsWrap.appendChild(dot);
    }
  }

  function updateControls() {
    var movable = maxIndex > 0;
    prevBtn.disabled = !movable;
    nextBtn.disabled = !movable;
  }

  function goTo(index, wrap) {
    if (wrap === undefined) wrap = true;
    if (maxIndex <= 0) {
      current = 0;
    } else if (wrap) {
      if (index < 0) index = maxIndex;
      if (index > maxIndex) index = 0;
      current = index;
    } else {
      current = Math.min(maxIndex, Math.max(0, index));
    }

    var first = track.children[0];
    if (!first) return;
    var itemWidth = first.getBoundingClientRect().width;
    var styles = window.getComputedStyle(track);
    var gap = parseFloat(styles.gap || styles.columnGap || '0') || 0;
    var offset = current * (itemWidth + gap);
    track.style.transform = 'translateX(-' + offset + 'px)';

    var dots = dotsWrap.querySelectorAll('.carousel-dot');
    dots.forEach(function(d, i) {
      d.classList.toggle('active', i === current);
    });
    updateControls();
  }

  function rebuild() {
    refreshCounts();
    renderDots();
    goTo(current, false);
  }

  async function loadReviewsFromApi() {
    try {
      var res = await fetch('/api/reviews');
      if (!res.ok) return;
      var data = await res.json();
      if (!data || !Array.isArray(data.reviews) || data.reviews.length < 1) return;

      track.innerHTML = '';
      data.reviews.forEach(function(item) {
        track.appendChild(buildSlide(item));
      });
      current = 0;
      rebuild();
    } catch (_) {
      // keep static fallback slides
    }
  }

  function startAuto() {
    stopAuto();
    if (maxIndex <= 0) return;
    autoInterval = setInterval(function() { goTo(current + 1, true); }, 5000);
  }

  function stopAuto() {
    if (autoInterval) { clearInterval(autoInterval); autoInterval = null; }
  }

  prevBtn.addEventListener('click', function() { goTo(current - 1, true); startAuto(); });
  nextBtn.addEventListener('click', function() { goTo(current + 1, true); startAuto(); });
  window.addEventListener('resize', rebuild);

  if (carousel) {
    carousel.addEventListener('mouseenter', stopAuto);
    carousel.addEventListener('mouseleave', startAuto);
  }

  rebuild();
  loadReviewsFromApi();
  startAuto();
})();
</script>
